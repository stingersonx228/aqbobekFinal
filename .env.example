# Ключ от Groq (Llama 3.3 70b)
GROQ_KEY=your_groq_api_key_here

# Токен Telegram Бота
TG_TOKEN=your_telegram_bot_token_here

# Секретный токен для общения между ботом и бэкендом
INTERNAL_SECRET_TOKEN=generate_a_very_long_random_string_here

# Настройки бэкенда
DATABASE_URL=sqlite+aiosqlite:///./aqbobek.db
PORT=8001
